#include <stdio.h>
#include <omp.h>

double f(double x) {
    return x * x;
}

int main() {
    double a, b, h, global_total = 0.0;
    int n;

    printf("Enter a, b, and n: ");
    scanf("%lf %lf %d", &a, &b, &n);

    h = (b - a) / n;
    global_total = (f(a) + f(b)) / 2.0;

    double local_sum = 0.0;

    #pragma omp parallel for reduction(+:local_sum)
    for (int i = 1; i <= n - 1; i++) {
        local_sum += f(a + i * h);
    }
    #pragma omp critical
    {
        global_total += local_sum;
    }

    global_total = global_total * h;

    printf("\nResult: %f\n", global_total);

    return 0;
}
