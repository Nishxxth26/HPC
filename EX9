    int n, max_val;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    int collection[n];
    printf("Enter %d integers:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &collection[i]);
    }
    max_val = INT_MIN;
    #pragma omp parallel for reduction(max:max_val)
    for (int i = 0; i < n; i++) {
        if (collection[i] > max_val) {
            max_val = collection[i];
        }
    }

    printf("\nThe maximum element is: %d\n", max_val);

    return 0;
}

