#include <stdio.h>
#include <stdlib.h>
#include <omp.h>

int main() {
    int i,N,CONST_VAL;
    int *A;

    printf("Enter no of elements:");
    scanf("%d",&N);

    // Allocate memory
    A = (int*) malloc(N * sizeof(int));

    // Initialize array
    for(i = 0; i < N; i++) {
        A[i] = rand()%10;
    }
    printf("Enter const value to be added: ");
    scanf("%d",&CONST_VAL);

    printf("\nInput taken : ");
    for(i = 0;i < N;i++){
            printf("%d ",A[i]);
    }

    // Parallel loop to add constant
    #pragma omp parallel for
    for(i = 0; i < N; i++) {
        A[i] = A[i] + CONST_VAL;
    }

    // Print sample output
    printf("\nOutput given: ");
    for(i = 0; i < N; i++) {
        printf("%d ", A[i]);
    }

    printf("\n");
    // Free memory
    free(A);

    return 0;
}
